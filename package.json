		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^25.5.0",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"mode-watcher": "^1.1.0",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
